<odoo>
    <record id="view_account_move_custom_list" model="ir.ui.view">
        <field name="name">account.custom.type.list</field>
        <field name="model">account.custom.type</field>
        <field name="arch" type="xml">
            <list string="Types">
                <field name="type" string="Name"/>
                <field name="des" string="des"/>
            </list>
        </field>
    </record>

    <record id="view_account_move_custom_form" model="ir.ui.view">
        <field name="name">account.custom.type.form</field>
        <field name="model">account.custom.type</field>
        <field name="arch" type="xml">
            <form string="Type">
                <sheet>
                    <group>
                        <field name="type" string="Name" placeholder="type  ..."/>
                        <field name="des" string="des" placeholder="des  ..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_account_moves_custom_type" model="ir.actions.act_window">
        <field name="name">Type</field>
        <field name="res_model">account.custom.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_account_custom_type"
        name="Type"
        parent="account.menu_finance_configuration"
        action="action_account_moves_custom_type"
    />
</odoo>