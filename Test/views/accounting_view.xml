<odoo>
    <record id="view_move_form_inherit_type" model="ir.ui.view">
        <field name="name">account.move.form.inherit.type</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='ref']" position="after">
                <field name="custom_type"/>
            </xpath>
        </field>
    </record>


    <record id="action_account_moves_custom_type" model="ir.actions.act_window">
        <field name="name">Type</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem
        id="menu_account_custom_type"
        name="Type"
        parent="account.menu_finance_configuration"
        action="action_account_moves_custom_type"
    />
</odoo>