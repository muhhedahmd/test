<odoo>
    <record id="view_estate_type_list" model="ir.ui.view">
        <field name="name">estate_type.list</field>
        <field name="model">estate_type</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
                <field name="Test2"/>
            </list>
        </field>
    </record>

    <record id="view_estate_type_form" model="ir.ui.view">
        <field name="name">estate_type.form</field>
        <field name="model">estate_type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                        <field name="Test2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_estate_type_search" model="ir.ui.view">
        <field name="name">estate_type.search</field>
        <field name="model">estate_type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Test" name="test" domain="[('code','=','test')]">
                </filter>
                <group expand ="0" string="Group By">
            </search>
        </field>
    </record>

    <record id="action_estate_type" model="ir.actions.act_window">
        <field name="name">Estate Type</field>
        <field name="res_model">estate_type</field>
        <field name="view_mode">list,form</field>
    </record>
   
    <menuitem id="estate_menu_root" name="Real Estate"/>
    <menuitem id="estate2_menu_first_level" name="Types" parent="estate_menu_root"/>
    <menuitem id="estate2_menu_action" name="Type" parent="estate2_menu_first_level" action="action_estate_type"/>
    <menuitem id="estate2_menu_first_level" name="Types" parent="estate_menu_root"/>
    <menuitem id="estate2_menu_action" name="Type" parent="estate2_menu_first_level" action="action_estate_type"/>
</odoo> 
</odoo> 