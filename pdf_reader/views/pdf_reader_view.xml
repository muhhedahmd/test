<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_pdf_reader_form" model="ir.ui.view">
        <field name="name">pdf.reader.form</field>
        <field name="model">pdf.reader</field>
        <field name="arch" type="xml">
            <form string="PDF Reader">
                <header>
                    <button name="action_read_pdf" string="1. Extract Data (Preview)" type="object" class="oe_highlight"/>
                    <button name="action_create_invoice" string="2. Create Draft Invoice" type="object" class="oe_highlight" attrs="{'invisible': [('document_type', '!=', 'invoice')]}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="document_type"/>
                            <field name="pdf_file" filename="pdf_filename"/>
                            <field name="pdf_filename" invisible="1"/>
                        </group>
                        <group string="Extracted Preview">
                            <field name="partner_name"/>
                            <field name="invoice_date"/>
                            <field name="invoice_ref"/>
                        </group>
                    </group>
                    <group>
                        <field name="prompt"/>
                    </group>
                    <notebook>
                        <page string="Extracted Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="col1" string="Description"/>
                                    <field name="col2" string="Quantity"/>
                                    <field name="col3" string="Price"/>
                                    <field name="col4" string="Taxes"/>
                                    <field name="col5" string="Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Raw AI Result">
                            <field name="result" nolabel="1" placeholder="Raw AI JSON will appear here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_pdf_reader_tree" model="ir.ui.view">
        <field name="name">pdf.reader.tree</field>
        <field name="model">pdf.reader</field>
        <field name="arch" type="xml">
            <list string="PDF Readers">
                <field name="name"/>
                <field name="document_type"/>
                <field name="pdf_filename"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pdf_reader" model="ir.actions.act_window">
        <field name="name">PDF Readers</field>
        <field name="res_model">pdf.reader</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_pdf_reader_root" name="PDF Reader" sequence="10"/>
    <menuitem id="menu_pdf_reader_action" name="PDF Reader" parent="menu_pdf_reader_root" action="action_pdf_reader" sequence="10"/>

</odoo>
